# Cloudflare R2 — Vercel Project Settings ve yerel "sync" scripti ile AYNI isimler.
# Endpoint: R2 > bucket > Settings > S3 API
# Köşeli parantez KULLANMAYIN — sadece hesap kimliği:
#   DOĞRU:   https://b75893bc4ac2048d5394aa135376eb3f.r2.cloudflarestorage.com
#   YANLIŞ:  https://<b75893bc4ac2048d5394aa135376eb3f>.r2.cloudflarestorage.com

S3_ENDPOINT=https://________________.r2.cloudflarestorage.com
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Bos: nesneler bucket kokunde "T-shirt/1.png" gibi.
# Dolu (ornek: mockups): nesneler "mockups/T-shirt/1.png" — Vercel'de S3_PREFIX=mockups olmali.
S3_PREFIX=

# Vercel'de uretilen mockup'lar gecici olarak buraya yuklenir (katalogdan ayri; degistirmesen de olur).
# S3_WORKSPACE_OUTPUT_PREFIX=workspace-generated

# R2 icin genelde "auto" yeterli
S3_REGION=auto

# --- Bucketa yukleme (scripts/sync-mockups-to-r2.sh) ---
# Yerel Mockups yolu; bos birakilirsa proje kokundeki ./Mockups kullanilir.
# MOCKUPS_DIR=/Users/you/.../Mockups
#
# Bucket yapisi yerel Mockups ile AYNI olmali (slash ile alt klasor):
#   DOGRU:  CC Long/1.png   (CC Long klasorunun ICINDE 1.png)
#   YANLIS: CC Long:1.png  (kokte iki nokta — placement ve URL'ler / ile eslesmez)
